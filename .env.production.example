# Production environment template
# Copy to .env.production and replace all <...> placeholders.

APP_ENV=production

BACKEND_SERVICE_NAME=kb-backend
BACKEND_VERSION=2.1.0
BACKEND_PORT=8000
DATABASE_URL=postgresql+psycopg://kb_app:<POSTGRES_APP_PASSWORD>@postgres:5432/kb
JWT_SECRET=<GENERATE_AT_LEAST_32_CHAR_RANDOM_SECRET>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_SECURE=true
REFRESH_COOKIE_HTTPONLY=true
REFRESH_COOKIE_SAMESITE=strict
MAX_UPLOAD_SIZE_BYTES=10485760

FRONTEND_PUBLIC_APP_NAME=<YOUR_COMPANY_KB_PORTAL>
FRONTEND_PORT=5173

NGINX_PORT=8080

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=kb
POSTGRES_USER=kb_app
POSTGRES_PASSWORD=<STRONG_POSTGRES_PASSWORD>

REDIS_HOST=redis
REDIS_PORT=6379

MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=<UNIQUE_MINIO_ADMIN_USER>
MINIO_ROOT_PASSWORD=<STRONG_MINIO_PASSWORD>
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

ONLYOFFICE_PORT=8082
ONLYOFFICE_JWT_ENABLED=true
ONLYOFFICE_JWT_SECRET=<STRONG_ONLYOFFICE_JWT_SECRET>

# Bootstrap admin operator inputs
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=<STRONG_INITIAL_ADMIN_PASSWORD>
BOOTSTRAP_ADMIN_DEPARTMENT=platform
