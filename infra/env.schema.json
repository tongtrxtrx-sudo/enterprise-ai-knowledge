{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Runtime environment schema",
    "type": "object",
    "required": [
        "BACKEND_SERVICE_NAME",
        "BACKEND_VERSION",
        "FRONTEND_PUBLIC_APP_NAME",
        "FRONTEND_PORT"
    ],
    "properties": {
        "BACKEND_SERVICE_NAME": {
            "type": "string",
            "minLength": 1
        },
        "BACKEND_VERSION": {
            "type": "string",
            "minLength": 1
        },
        "BACKEND_PORT": {
            "type": "string",
            "pattern": "^[0-9]{2,5}$"
        },
        "FRONTEND_PUBLIC_APP_NAME": {
            "type": "string",
            "minLength": 1
        },
        "FRONTEND_PORT": {
            "type": "string",
            "pattern": "^[0-9]{2,5}$"
        }
    },
    "additionalProperties": true
}
